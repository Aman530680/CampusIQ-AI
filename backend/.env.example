# Environment Configuration
APP_NAME=CampusIQ AI
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DB_HOST=mysql
DB_PORT=3306
DB_NAME=campusiq
DB_USER=campusiq_user
DB_PASSWORD=campusiq_pass
DATABASE_URL=mysql+pymysql://campusiq_user:campusiq_pass@mysql:3306/campusiq

# Redis
REDIS_URL=redis://redis:6379/0

# AI / LLM
OPENAI_API_KEY=your-openai-api-key
LLM_MODEL=gpt-3.5-turbo
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Storage
STORAGE_PATH=/app/storage
VECTOR_DB_PATH=/app/storage/vector_db
MODELS_PATH=/app/storage/models
REPORTS_PATH=/app/storage/reports
UPLOADS_PATH=/app/storage/uploads

# Dataset
DATASET_PATH=/app/storage/uploads/CampusIQ_20000_Students_Dataset.xlsx

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80
